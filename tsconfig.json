{
  "compilerOptions": {
    "target": "ES2020",

    "module": "commonjs",

    "lib": ["ES2020"],

    "types": ["node"],

    "outDir": "./dist",

    "rootDir": "./src",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "experimentalDecorators": true,

    "emitDecoratorMetadata": true,

    "resolveJsonModule": true,

    "paths": {
      "@/*": ["./src/*"]
    }
  },

  "include": ["src/**/*"],

  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
